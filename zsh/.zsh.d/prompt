#!/bin/zsh

# Function to print a horizontal line separator, then timestamp row
print_separator() {
    local cols=${COLUMNS:-$(tput cols)}
    local timestamp=$(date '+%H:%M:%S')
    local separator_char="─"

    # Full-width horizontal line
    local line=$(printf "%*s" "$cols" | tr ' ' "$separator_char")
    echo "\033[2m${line}\033[0m"

    # Timestamp row
    echo "[$timestamp]"
}

precmd() {
    echo ""
    print_separator
}

export PS1='%(?..(%?%) )%~ %% '
